#!/usr/bin/env bash

set -euo pipefail

current_script_path=${BASH_SOURCE[0]}
plugin_dir=$(dirname "$(dirname "$current_script_path")")

# shellcheck source=./lib/utils.bash
. "${plugin_dir}/lib/utils.bash"

# Simply use list_all_versions since it now directly fetches from the GitHub API
version="$(list_all_versions)"

printf "%s\n" "$version"
